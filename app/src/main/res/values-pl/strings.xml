    <string name="onboarding_welcome_subtitle">Twój towarzysz urządzenia</string>
    <string name="onboarding_welcome_body1">Octi to narzędzie dla osób z wieloma urządzeniami Android.</string>
    <string name="onboarding_welcome_body2">Utrzymuje cię w pętli ze wszystkimi twoimi urządzeniami. Czy to twój telefon, tablet czy jakikolwiek inny gadżet z zainstalowanym Octi, otrzymasz kluczowe szczegóły na pierwszy rzut oka.</string>
    <string name="onboarding_welcome_body3">Uaktualnij do Octi Pro, aby uzyskać dodatkowe funkcje i wesprzeć rozwój.</string>
    <string name="onboarding_welcome_beta_hint">Chcę tylko zaznaczyć, że to wersja beta, więc dziękuję za cierpliwość, podczas gdy cały czas udoskonalam aplikację!</string>
    <string name="onboarding_features_page1_title">Wszystkie urządzenia w skrócie</string>
    <string name="onboarding_features_page1_body">Zobacz baterię, Wi-Fi i łączność na wszystkich urządzeniach z systemem Android.</string>
    <string name="onboarding_features_page2_title">Płynna synchronizacja schowka</string>
    <string name="onboarding_features_page2_body">Skopiuj na jednym urządzeniu, wklej na innym. Twój schowek wędruje razem z tobą.</string>
    <string name="onboarding_features_page3_title">Razem lepiej</string>
    <string name="onboarding_features_page3_body">Zainstaluj Octi na wielu urządzeniach i połącz je przez usługę synchronizacji. Im więcej urządzeń, tym bardziej przydatne staje się Octi.</string>
    <string name="onboarding_privacy_subtitle">Polityka prywatności</string>
    <string name="onboarding_privacy_body1">Octi nie ma reklam i nie sprzedaje danych użytkowników.</string>
    <string name="onboarding_privacy_sync_explanation">Twoje dane są synchronizowane przez Dysk Google lub Octi Server. Octi nie ma dostępu do twoich zsynchronizowanych danych.</string>
    <string name="updatecheck_setting_enabled_label">Sprawdzanie aktualizacji</string>
    <string name="updatecheck_setting_enabled_explanation">Zezwól Octi na sprawdzanie aktualizacji, aby poinformować cię, gdy nowa wersja będzie dostępna.</string>
