    <string name="onboarding_welcome_subtitle">Din enhetsvenn</string>
    <string name="onboarding_welcome_body1">Octi er et verktøy for personer med flere Android-enheter.</string>
    <string name="onboarding_welcome_body2">Holder deg oppdatert med alle enhetene dine. Enten det er telefonen din, nettbrettet eller et annet Octi-enhet får du nøkkelinformasjon på et øyeblikk.</string>
    <string name="onboarding_welcome_body3">Oppgrader til Octi Pro for å få ekstra funksjoner og støtte utviklingen.</string>
    <string name="onboarding_welcome_beta_hint">Bare en liten notis: Dette er en betaversjon, så takk for tålmodigheten mens jeg fortsetter å forbedre appen!</string>
    <string name="onboarding_features_page1_title">Alle enhetene dine på ett sted</string>
    <string name="onboarding_features_page1_body">Se batteri, WiFi og tilkobling på tvers av alle Android-enhetene dine.</string>
    <string name="onboarding_features_page2_title">Smidig utklipptavle-synkronisering</string>
    <string name="onboarding_features_page2_body">Kopier på én enhet, lim inn på en annen. Utklipptavlen din følger deg.</string>
    <string name="onboarding_features_page3_title">Bedre sammen</string>
    <string name="onboarding_features_page3_body">Installer Octi på flere enheter og koble dem sammen via en synkroniseringstjeneste. Jo flere enheter, desto mer nyttig blir Octi.</string>
    <string name="onboarding_privacy_subtitle">Personvernerklæring</string>
    <string name="onboarding_privacy_body1">Octi har ingen annonser og selger ikke brukerdata.</string>
    <string name="onboarding_privacy_sync_explanation">Dataene dine synkroniseres via Google Disk eller Octi Server. Octi har ikke tilgang til de synkroniserte dataene dine.</string>
    <string name="updatecheck_setting_enabled_label">Oppdateringssjekk</string>
    <string name="updatecheck_setting_enabled_explanation">Tillat at Octi sjekker etter oppdateringer slik at du får beskjed om en nyere versjon er tilgjengelig.</string>
