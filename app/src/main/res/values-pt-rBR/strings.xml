    <string name="permission_battery_optimization_label">Otimização de bateria</string>
    <string name="permission_battery_optimization_desc">Desative a otimização de bateria para permitir a sincronização sem abrir o app.</string>
    <string name="permission_reliability_label">Confiabilidade</string>
    <string name="permission_reliability_title">Melhorar a confiabilidade</string>
    <string name="permission_reliability_desc">O Octi precisa funcionar em segundo plano para manter seus dispositivos sincronizados. Desativar as otimizações de bateria garante sincronização confiável sem precisar abrir o aplicativo.</string>
    <string name="permission_reliability_settings_action">Abrir configurações</string>
    <string name="permission_notifications_post_label">Postar notificações</string>
    <string name="permission_notifications_post_desc">A permissão de postar notificações permite ao Octi avisar sobre eventos em outros dispositivos que você configurou.</string>
