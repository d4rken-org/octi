    <string name="onboarding_welcome_subtitle">Seu companheiro de dispositivos</string>
    <string name="onboarding_welcome_body1">Octi é uma ferramenta para pessoas com vários dispositivos Android.</string>
    <string name="onboarding_welcome_body2">Mantém você informado sobre todos os seus dispositivos. Seja telefone, tablet ou qualquer outro dispositivo com Octi instalado, você verá as principais informações em um piscar de olhos.</string>
    <string name="onboarding_welcome_body3">Atualize para o Octi Pro para ter recursos extras e apoiar o desenvolvimento.</string>
    <string name="onboarding_welcome_beta_hint">Atenção: essa é uma versão beta, obrigado pela paciência enquanto continuo melhorando o app!</string>
    <string name="onboarding_features_page1_title">Todos os seus dispositivos de relance</string>
    <string name="onboarding_features_page1_body">Veja bateria, Wi-Fi e conectividade em todos os seus dispositivos Android.</string>
    <string name="onboarding_features_page2_title">Sincronização de área de transferência</string>
    <string name="onboarding_features_page2_body">Copie em um dispositivo, cole em outro. Sua área de transferência vai com você.</string>
    <string name="onboarding_features_page3_title">Melhor juntos</string>
    <string name="onboarding_features_page3_body">Instale o Octi em vários dispositivos e conecte-os por um serviço de sincronização. Quanto mais dispositivos, mais útil o Octi fica.</string>
    <string name="onboarding_privacy_subtitle">Política de Privacidade</string>
    <string name="onboarding_privacy_body1">Octi não tem anúncios e não vende dados de usuário.</string>
    <string name="onboarding_privacy_sync_explanation">Seus dados são sincronizados via Google Drive ou Octi Server. O Octi não tem acesso aos seus dados sincronizados.</string>
    <string name="updatecheck_setting_enabled_label">Verificação de atualizações</string>
    <string name="updatecheck_setting_enabled_explanation">Permitir que Octi verifique atualizações para informar se há uma versão mais recente disponível.</string>
