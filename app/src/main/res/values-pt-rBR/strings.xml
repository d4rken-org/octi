    <string name="sync_setting_background_mobile_desc">Permitir sincronização em segundo plano usando sua rede móvel caso o Wi-Fi não esteja disponível.</string>
    <string name="sync_setting_mobile_desc">Permitir sincronização usando sua conexão de dados móveis quando o Wi-Fi estiver indisponível.</string>
    <string name="sync_setting_charging_enable_title">Mais rápido durante o carregamento</string>
