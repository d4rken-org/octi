    <string name="permission_location_label">Permissão de localização</string>
    <string name="permission_location_desc">A permissão de localização permite que Octi exiba os nomes das suas redes Wi-Fi ou mostre a posição atual do seu dispositivo.</string>
    <string name="permission_battery_optimization_label">Otimizações de bateria</string>
    <string name="permission_battery_optimization_desc">Desative as otimizações de bateria para permitir sincronização sem abrir o aplicativo.</string>
    <string name="permission_reliability_label">Fiabilidade</string>
    <string name="permission_reliability_title">Melhorar a fiabilidade</string>
    <string name="permission_reliability_desc">O Octi precisa de ser executado em segundo plano para manter os seus dispositivos sincronizados. Desativar as otimizações de bateria garante uma sincronização fiável sem precisar de abrir a aplicação.</string>
    <string name="permission_reliability_settings_action">Abrir definições</string>
    <string name="permission_notifications_post_label">Postar notificações</string>
    <string name="permission_notifications_post_desc">A permissão de postar notificações permite que Octi notifique você sobre eventos em outros dispositivos que você configurou.</string>
    <string name="sync_setting_background_enable_title">Sincronização em segundo plano</string>
    <string name="sync_setting_background_enable_desc">Sincronizar dados quando o aplicativo não estiver aberto.</string>
    <string name="sync_setting_background_mobile_label">Rede móvel</string>
    <string name="sync_setting_background_mobile_desc">Permitir sincronização em segundo plano usando sua conexão de rede móvel se Wi-Fi não estiver disponível.</string>
    <string name="sync_setting_mobile_desc">Permitir a sincronização utilizando a sua ligação de rede móvel se o Wi-Fi não estiver disponível.</string>
    <string name="sync_setting_charging_enable_title">Mais rápido ao carregar</string>
    <string name="sync_setting_charging_enable_desc">Utilizar um intervalo de sincronização mais curto enquanto o dispositivo está a carregar.</string>
    <string name="sync_setting_charging_interval_label">Intervalo de carregamento</string>
    <string name="sync_setting_category_foreground_label">Sincronização em primeiro plano</string>
