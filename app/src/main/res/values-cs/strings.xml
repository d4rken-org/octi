    <string name="onboarding_features_page1_body">Sledujte stav baterie, Wi-Fi a připojení na všech svých zařízeních Android.</string>
    <string name="onboarding_features_page2_title">Bezproblémová synchronizace schránky</string>
    <string name="onboarding_features_page2_body">Zkopírujte na jednom zařízení, vložte na jiném. Vaše schránka cestuje s vámi.</string>
    <string name="onboarding_features_page3_title">Spolu je lépe</string>
    <string name="onboarding_features_page3_body">Nainstalujte Octi na více zařízení a propojte je prostřednictvím synchronizační služby. Čím více zařízení, tím užitečnější Octi je.</string>
