<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="BatteryWidget">

    </style>

    <style name="BatteryWidget.Container">
        <item name="android:background">@drawable/widget_background</item>
        <item name="android:clipToOutline">true</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="BatteryWidget.TextPercent">
        <item name="android:textColor">@color/widgetOnContainer</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BatteryWidget.ConfigSection" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerLow</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardCornerRadius">16dp</item>
    </style>
</resources>