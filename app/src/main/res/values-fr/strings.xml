    <string name="permission_reliability_label">Fiabilité</string>
    <string name="permission_reliability_title">Améliorer la fiabilité</string>
    <string name="permission_reliability_desc">Octi doit s’exécuter en arrière-plan pour maintenir vos appareils synchronisés. Désactiver les optimisations de batterie garantit une synchronisation fiable sans avoir à ouvrir l’application.</string>
