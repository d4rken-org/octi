    <string name="permission_location_desc">L’autorisation de localisation permet à Octi d’afficher le noms de vos Wi-Fi ou d’afficher la position actuelle de votre appareil.</string>
    <string name="permission_battery_optimization_label">Optimisations de batterie</string>
