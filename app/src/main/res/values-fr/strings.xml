    <string name="onboarding_welcome_subtitle">Le compagnon de vos appareils</string>
    <string name="onboarding_welcome_body1">Octi est un outil pour les personnes qui utilisent plusieurs appareils Android.</string>
    <string name="onboarding_welcome_body2">Avec Octi installé sur votre téléphone, votre tablette ou sur tout autre gadget Android, connaissez l’état de vos appareils en un coup d’œil,.</string>
    <string name="onboarding_welcome_body3">Passez à Octi Pro pour débloquer des fonctions supplémentaires et financer le développement.</string>
    <string name="onboarding_welcome_beta_hint">Ceci est une version bêta. Faites preuve de patience alors que je continue d\'améliorer l\'appli.</string>
    <string name="onboarding_features_page1_title">Tous vos appareils en un coup d\'œil</string>
    <string name="onboarding_features_page1_body">Consultez la batterie, le Wi-Fi et la connectivité sur tous vos appareils Android.</string>
    <string name="onboarding_features_page2_title">Synchronisation du presse-papiers fluide</string>
    <string name="onboarding_features_page2_body">Copiez sur un appareil, collez sur un autre. Votre presse-papiers vous suit partout.</string>
    <string name="onboarding_features_page3_title">Ensemble, c\'est mieux</string>
    <string name="onboarding_features_page3_body">Installez Octi sur plusieurs appareils et connectez-les via un service de synchronisation. Plus il y a d\'appareils, plus Octi devient utile.</string>
    <string name="onboarding_privacy_subtitle">Politique de confidentialité</string>
    <string name="onboarding_privacy_body1">Octi n’affiche pas de publicités et ne vend pas les données des utilisateurs.</string>
    <string name="onboarding_privacy_sync_explanation">Vos données sont synchronisées via Google Drive ou Octi Server. Octi n’a pas accès à vos données synchronisées.</string>
    <string name="updatecheck_setting_enabled_label">Recherche de mises à jour</string>
    <string name="updatecheck_setting_enabled_explanation">Permettre à Octi de chercher les mises à jour et de vous informer si une version plus récente est proposée.</string>
