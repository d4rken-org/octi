    <string name="permission_location_label">Standort Berechtigung</string>
    <string name="permission_location_desc">Die Standortberechtigung ermöglicht es Octi, Ihre WLAN-Namen anzuzeigen oder Ihnen die aktuelle Position Ihres Geräts zu zeigen.</string>
    <string name="permission_battery_optimization_label">Akku</string>
    <string name="permission_battery_optimization_desc">Deaktivieren Sie Akkuoptimierungen, um Synchronisation ohne Öffnen der App zu ermöglichen.</string>
    <string name="permission_reliability_label">Zuverlässigkeit</string>
    <string name="permission_reliability_title">Zuverlässigkeit verbessern</string>
    <string name="permission_reliability_desc">Octi muss im Hintergrund laufen, um deine Geräte synchron zu halten. Das Deaktivieren der Akkuoptimierungen sorgt für eine zuverlässige Synchronisierung, ohne die App öffnen zu müssen.</string>
    <string name="permission_reliability_settings_action">Einstellungen öffnen</string>
    <string name="permission_notifications_post_label">Benachrichtigung anzeigen</string>
    <string name="permission_notifications_post_desc">Die Berechtigung zum Senden von Benachrichtigungen ermöglicht es Octi, Sie über Ereignisse auf anderen Geräten zu benachrichtigen, die Sie konfiguriert haben.</string>
    <string name="sync_setting_background_enable_title">Hintergrund Synchronisation</string>
