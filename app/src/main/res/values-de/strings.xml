    <string name="sync_setting_background_mobile_label">Mobilfunk</string>
    <string name="sync_setting_background_mobile_desc">Hintergrundsynchronisation über Ihr Mobilfunknetz zulassen, wenn WLAN nicht verfügbar ist.</string>
    <string name="sync_setting_mobile_desc">Synchronisierung über deine Mobilfunkverbindung zulassen, wenn WLAN nicht verfügbar ist.</string>
    <string name="sync_setting_charging_enable_title">Schneller beim Laden</string>
    <string name="sync_setting_charging_enable_desc">Kürzeres Synchronisierungsintervall verwenden, während das Gerät aufgeladen wird.</string>
