    <string name="permission_location_label">Permesso di posizione</string>
    <string name="permission_location_desc">Il permesso di posizione consente a Octi di visualizzare i nomi delle tue reti Wi-Fi o mostrarti la posizione attuale del tuo dispositivo.</string>
    <string name="permission_battery_optimization_label">Ottimizzazione batteria</string>
    <string name="permission_battery_optimization_desc">Disabilita le ottimizzazioni della batteria per consentire la sincronizzazione senza dover aprire l\'app.</string>
    <string name="permission_reliability_label">Affidabilità</string>
    <string name="permission_reliability_title">Migliora l\'affidabilità</string>
    <string name="permission_reliability_desc">Octi deve essere eseguito in background per mantenere i tuoi dispositivi sincronizzati. Disabilitare le ottimizzazioni della batteria garantisce una sincronizzazione affidabile senza dover aprire l\'app.</string>
    <string name="permission_reliability_settings_action">Apri impostazioni</string>
    <string name="permission_notifications_post_label">Notifiche</string>
    <string name="permission_notifications_post_desc">Il permesso per le notifiche di pubblicazione consente a Octi di avvisarti su eventi su altri dispositivi che hai configurato.</string>
    <string name="sync_setting_background_enable_title">Sincronizzazione in background</string>
    <string name="sync_setting_background_enable_desc">Sincronizza i dati quando l\'app non è aperta.</string>
    <string name="sync_setting_background_mobile_label">Rete mobile</string>
    <string name="sync_setting_background_mobile_desc">Consenti la sincronizzazione in background utilizzando la connessione dati mobile se il Wi-Fi non è disponibile.</string>
    <string name="sync_setting_mobile_desc">Consenti la sincronizzazione tramite la rete mobile se il Wi-Fi non è disponibile.</string>
    <string name="sync_setting_charging_enable_title">Più veloce durante la ricarica</string>
    <string name="sync_setting_charging_enable_desc">Usa un intervallo di sincronizzazione più breve mentre il dispositivo è in carica.</string>
