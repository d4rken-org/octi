    <string name="permission_reliability_label">Αξιοπιστία</string>
    <string name="permission_reliability_title">Βελτίωση αξιοπιστίας</string>
    <string name="permission_reliability_desc">Το Octi χρειάζεται να λειτουργεί στο παρασκήνιο για να διατηρεί τις συσκευές σας συγχρονισμένες. Η απενεργοποίηση βελτιστοποιήσεων μπαταρίας εξασφαλίζει αξιόπιστο συγχρονισμό χωρίς να ανοίξετε την εφαρμογή.</string>
    <string name="permission_reliability_settings_action">Ανοιχτούν ρυθμίσεις</string>
    <string name="permission_notifications_post_label">Αποστολή ειδοποιήσεων</string>
