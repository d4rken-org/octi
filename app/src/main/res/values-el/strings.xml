    <string name="settings_support_label">Υποστήριξη</string>
    <string name="debug_debuglog_sensitive_information_message">Το αρχείο αυτό περιέχει ευαίσθητες πληροφορίες (π.χ. τις εγκατεστημένες εφαρμογές σας). Μοιραστείτε το μόνο με έμπιστα άτομα.</string>
