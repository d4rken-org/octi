    <string name="permission_location_desc">El permiso de ubicación permite que Octi muestre tus nombres de la Wi-Fi o te muestra la posición actual de tu dispositivo.</string>
    <string name="permission_battery_optimization_label">Optimizaciones de la batería</string>
    <string name="permission_battery_optimization_desc">Deshabilitar las optimizaciones de la batería para permitir la sincronización sin abrir la aplicación.</string>
    <string name="permission_reliability_label">Fiabilidad</string>
    <string name="permission_reliability_title">Mejorar la fiabilidad</string>
    <string name="permission_reliability_desc">Octi necesita ejecutarse en segundo plano para mantener tus dispositivos sincronizados. Desactivar las optimizaciones de batería garantiza una sincronización fiable sin necesidad de abrir la aplicación.</string>
    <string name="permission_reliability_settings_action">Abrir configuración</string>
    <string name="permission_notifications_post_label">Publicar las notificaciones</string>
    <string name="permission_notifications_post_desc">El permiso de notificaciones permite a Octi notificarte sobre los eventos en otros dispositivos que hayas configurado.</string>
