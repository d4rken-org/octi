    <string name="sync_setting_background_mobile_label">Red móvil</string>
    <string name="sync_setting_background_mobile_desc">Permitir la sincronización en segundo plano usando tu conexión de red móvil si la Wi-Fi no está disponible.</string>
    <string name="sync_setting_mobile_desc">Permitir la sincronización usando tu conexión de red móvil si el Wi-Fi no está disponible.</string>
    <string name="sync_setting_charging_enable_title">Más rápido al cargar</string>
