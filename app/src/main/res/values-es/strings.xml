    <string name="onboarding_welcome_subtitle">Tu compañero de dispositivos</string>
    <string name="onboarding_welcome_body1">Octi es una herramienta para personas con múltiples dispositivos Android.</string>
    <string name="onboarding_welcome_body2">Te mantiene al día con todos tus dispositivos. Ya sea tu teléfono, tablet o cualquier otro gadget con Octi instalado, obtendrás detalles clave de un vistazo.</string>
    <string name="onboarding_welcome_body3">Actualiza a Octi Pro para obtener funciones adicionales y apoyar el desarrollo.</string>
    <string name="onboarding_welcome_beta_hint">Solo para que sepas, esta es una versión beta, ¡así que gracias por tu paciencia mientras sigo mejorando la aplicación!</string>
    <string name="onboarding_features_page1_title">Todos tus dispositivos de un vistazo</string>
    <string name="onboarding_features_page1_body">Consulta la batería, WiFi y conectividad de todos tus dispositivos Android.</string>
    <string name="onboarding_features_page2_title">Sincronización del portapapeles sin interrupciones</string>
    <string name="onboarding_features_page2_body">Copia en un dispositivo, pega en otro. Tu portapapeles te acompaña.</string>
    <string name="onboarding_features_page3_title">Mejor juntos</string>
    <string name="onboarding_features_page3_body">Instala Octi en varios dispositivos y conectálos a través de un servicio de sincronización. Cuantos más dispositivos, más útil se vuelve Octi.</string>
    <string name="onboarding_privacy_subtitle">Política de privacidad</string>
    <string name="onboarding_privacy_body1">Octi no tiene anuncios y no vende datos de usuario.</string>
    <string name="onboarding_privacy_sync_explanation">Tus datos se sincronizan a través de Google Drive o Octi Server. Octi no tiene acceso a tus datos sincronizados.</string>
    <string name="updatecheck_setting_enabled_label">Verificación de actualizaciones</string>
    <string name="updatecheck_setting_enabled_explanation">Permitir que Octi verifique actualizaciones para informarte si hay una versión más reciente disponible.</string>
