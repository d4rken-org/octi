    <string name="permission_notifications_post_label">Notificacions</string>
    <string name="permission_notifications_post_desc">El permís de notificacions permet que l\'Octi us avisi sobre esdeveniments en altres dispositius que hàgiu configurat.</string>
    <string name="sync_setting_background_enable_title">Sincronització de fons</string>
    <string name="sync_setting_background_enable_desc">Sincronitza les dades quan l\'aplicació no està oberta.</string>
    <string name="sync_setting_background_mobile_label">Xarxa mòbil</string>
    <string name="sync_setting_background_mobile_desc">Permet la sincronització en segon pla mitjançant la connexió a la xarxa mòbil si no hi ha Wi-Fi disponible.</string>
    <string name="sync_setting_mobile_desc">Permet la sincronització mitjançant la connexió a la xarxa mòbil si no hi ha Wi-Fi disponible.</string>
