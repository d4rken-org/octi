    <string name="sync_octiserver_issues_type_device_not_registered">기기가 더 이상 연결되지 않음</string>
    <string name="sync_octiserver_error_device_not_registered">이 기기는 더 이상 서버에 등록되어 있지 않습니다. 다른 기기에서 연결을 끊고 다시 연결하거나 새 계정을 만드세요.</string>
    <string name="sync_octiserver_resume_sync_action">동기화 재개</string>
