<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="sync_octiserver_type_label">Octi Server</string>
    <string name="sync_octiserver_type_description">이 앱의 개발자가 만든 Octi용 오픈 소스 동기화 서버입니다. 데이터는 클라이언트 측에서 암호화되어 사용자의 기기만 복호화할 수 있습니다.

앱과 서버 모두 아직 개선 중이므로 다른 동기화 옵션보다 안정성이 낮을 수 있습니다.</string>
    <string name="sync_octiserver_add_create_action_hint">비활성 계정은 몇 주 후 삭제됩니다.</string>
    <string name="sync_octiserver_add_subtitle">Octi Server 계정 추가</string>
    <string name="sync_octiserver_add_link_action_hint">이미 연결된 다른 기기 접근이 필요합니다.</string>
    <string name="sync_octiserver_about_title">Octi Server 정보</string>
    <string name="sync_octiserver_about_desc">Octi Server는 darken이 만든 Octi용 오픈 소스 동기화 서버입니다.</string>
